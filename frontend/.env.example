# Example Frontend Environment Variables
# Copy this to .env.local and update with your actual values

# Backend API URL (without /api suffix for Vite app)
VITE_API_URL=http://localhost:5000

# Main marketing site URL
VITE_MAIN_APP_URL=http://localhost:3000

# Plan B Channel Manager placeholders (XML-first)
VITE_CHANNEL_MANAGER_ENABLED=false
VITE_CHANNEL_MANAGER_PRIMARY_PROVIDER=stayflexi
VITE_CHANNEL_MANAGER_XML_MODE=true
