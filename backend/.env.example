# Example Backend Environment Variables
# Copy this to .env and update with your actual values

NODE_ENV=production
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_USER=zevio_user
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_NAME=zevio_production

# JWT Configuration
JWT_SECRET=GENERATE_A_SECURE_RANDOM_KEY_HERE
JWT_EXPIRES_IN=7d

# URLs
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Email Configuration (Optional)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=YOUR_EMAIL_PASSWORD
SMTP_FROM=noreply@yourdomain.com

# Cashfree Payment Gateway
CASHFREE_ENV=TEST
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# Channel Manager (Stayflexi Plan B)
CHANNEL_MANAGER_ENABLED=true
CHANNEL_MANAGER_ALLOWED_PROVIDERS=stayflexi
CHANNEL_MANAGER_PROVIDER_STAYFLEXI_ENABLED=true
CHANNEL_MANAGER_PROVIDER_STAYFLEXI_SHARED_SECRET=your_stayflexi_shared_secret
CHANNEL_MANAGER_PROVIDER_STAYFLEXI_ENDPOINT=https://stayflexi.example.com/push-booking
# CHANNEL_MANAGER_ALLOWED_IPS=stayflexi.egress.ip.1,stayflexi.egress.ip.2
CHANNEL_MANAGER_DEFAULT_TIMEOUT_MS=10000
# CM Monitoring + Sync Logs — allowed admin email only
CM_MONITORING_ALLOWED_EMAIL=ranjith@gopafy.com
